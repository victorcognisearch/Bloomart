---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'mandarin';
  size?: 'sm' | 'md' | 'lg';
}

const { href, label, variant = 'primary', size = 'md' } = Astro.props;

// Bloomart.ro button style: sharp corners (0 radius), outline with teal border, transparent bg, mixed case, Oswald 500
const baseClasses = 'group relative inline-flex items-center justify-center font-display font-medium transition-colors duration-300';

const sizeClasses = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-[30px] py-[15px] text-base',
  lg: 'px-[36px] py-[18px] text-base',
};

const variantClasses = {
  // Primary = teal border, teal text, transparent bg, hover fills with teal
  primary: 'border border-brand text-brand bg-transparent hover:bg-brand hover:text-white',
  // Secondary = solid teal (used sparingly, for strong calls)
  secondary: 'border border-brand bg-brand text-white hover:bg-brand-dark hover:border-brand-dark',
  // Outline = for dark backgrounds (over hero image)
  outline: 'border border-white text-white bg-transparent hover:bg-white hover:text-brand',
  // Mandarin = solid orange with white text, used on green hero backgrounds for high contrast
  mandarin: 'border border-mandarin bg-mandarin text-white hover:bg-mandarin-light hover:border-mandarin-light',
};
---

<a href={href} class:list={[baseClasses, sizeClasses[size], variantClasses[variant]]}>
  <span class="relative z-10 flex items-center gap-2">
    {label}
    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
