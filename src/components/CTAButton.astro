---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
}

const { href, label, variant = 'primary', size = 'md' } = Astro.props;

const baseClasses = 'group relative inline-flex items-center justify-center font-display font-semibold uppercase tracking-wider rounded-full transition-all duration-300 overflow-hidden';

const sizeClasses = {
  sm: 'px-5 py-2.5 text-xs',
  md: 'px-7 py-3.5 text-sm',
  lg: 'px-9 py-4.5 text-base',
};

const variantClasses = {
  primary: 'bg-accent text-white shadow-[0_0_24px_rgba(255,107,53,0.35)] hover:shadow-[0_0_40px_rgba(255,107,53,0.55)] hover:scale-105',
  secondary: 'bg-brand text-white shadow-[0_0_24px_rgba(62,179,145,0.3)] hover:shadow-[0_0_40px_rgba(62,179,145,0.5)] hover:scale-105',
  outline: 'border-2 border-white/40 text-white backdrop-blur-sm hover:bg-white/10 hover:border-white/70 hover:scale-105',
};
---

<a href={href} class:list={[baseClasses, sizeClasses[size], variantClasses[variant]]}>
  <span class="relative z-10 flex items-center gap-2">
    {label}
    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
