---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  tag?: string;
}

const { title, description, href, image, tag } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
  <div class="aspect-[4/3] bg-dark-light overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="text-6xl font-display font-bold text-brand/20">BA</span>
      </div>
    )}
  </div>
  <div class="p-6">
    {tag && (
      <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider bg-brand/10 text-brand rounded-full mb-3">
        {tag}
      </span>
    )}
    <h3 class="text-xl font-display font-semibold text-text group-hover:text-brand transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-sm text-text-light leading-relaxed">
      {description}
    </p>
    <span class="inline-flex items-center mt-4 text-sm font-semibold text-brand group-hover:gap-2 transition-all">
      Detalii
      <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
