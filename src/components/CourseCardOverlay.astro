---
interface Props {
  title: string;
  href: string;
  image?: string;
}

const { title, href, image } = Astro.props;
---

<a href={href} class="group relative block aspect-[4/3] overflow-hidden rounded-xl cursor-pointer">
  {image ? (
    <img src={image} alt={title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" loading="lazy" />
  ) : (
    <div class="absolute inset-0 bg-dark-light"></div>
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/40 to-transparent group-hover:via-dark/50 transition-all duration-500"></div>
  <div class="absolute bottom-0 left-0 right-0 p-5">
    <h3 class="text-lg font-display font-bold text-white uppercase tracking-wide">{title}</h3>
    <div class="flex items-center gap-2 mt-2 overflow-hidden">
      <span class="text-sm font-semibold text-brand-light uppercase tracking-wider translate-y-6 group-hover:translate-y-0 transition-transform duration-500">Mai Mult</span>
      <svg class="w-4 h-4 text-brand-light -translate-x-8 group-hover:translate-x-0 transition-transform duration-500 delay-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
