---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-alt text-text border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div>
        <span class="text-2xl font-display font-semibold">Bloom<span class="text-brand">art</span></span>
        <p class="mt-4 text-sm text-text-light leading-relaxed">
          Cursuri de dans pentru copii si adulti in Bucuresti. Descopera bucuria dansului alaturi de noi.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-display font-semibold mb-4 text-brand" style="font-size:0.875rem">CURSURI</h3>
        <ul class="space-y-2">
          <li><a href="/cursuri-dans-adulti/" class="text-sm text-text-light hover:text-brand transition-colors">Dans Adulti</a></li>
          <li><a href="/cursuri-dans-copii/" class="text-sm text-text-light hover:text-brand transition-colors">Dans Copii</a></li>
          <li><a href="/cursuri-dansul-mirilor/" class="text-sm text-text-light hover:text-brand transition-colors">Dansul Mirilor</a></li>
          <li><a href="/orar-tarife/" class="text-sm text-text-light hover:text-brand transition-colors">Orar & Tarife</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-sm font-display font-semibold mb-4 text-brand" style="font-size:0.875rem">LINK-URI UTILE</h3>
        <ul class="space-y-2">
          <li><a href="/despre-bloomart/" class="text-sm text-text-light hover:text-brand transition-colors">Despre noi</a></li>
          <li><a href="/galerie/" class="text-sm text-text-light hover:text-brand transition-colors">Galerie</a></li>
          <li><a href="/contact/" class="text-sm text-text-light hover:text-brand transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-display font-semibold mb-4 text-brand" style="font-size:0.875rem">CONTACT</h3>
        <ul class="space-y-3 text-sm text-text-light">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Tabacarilor 14, Bucuresti</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+40746423423" class="hover:text-brand transition-colors">+40 746 423 423</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contact@bloomart.ro" class="hover:text-brand transition-colors">contact@bloomart.ro</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-light">
        &copy; {currentYear} Bloomart Academy. Toate drepturile rezervate. | Developed by <a href="https://cognisearch.ro" target="_blank" rel="noopener noreferrer" class="hover:text-brand transition-colors">CogniSearch</a>
      </p>
    </div>
  </div>
</footer>
