---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import CourseCardOverlay from '../../components/CourseCardOverlay.astro';
---

<Layout
  title="Cursuri Dans Copii București"
  description="Cursuri de dans pentru copii la BloomArt Academy București — Dans Modern, Street Dance, Baby Dance. Antrenori acreditați, grupe pe vârste."
>

  <!-- ========== HERO ========== -->
  <section class="relative pt-20 pb-10 lg:pt-24 lg:pb-12 overflow-hidden bg-brand">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-1 bg-mandarin rounded-full"></span>
        <span class="text-white text-sm font-semibold tracking-wider">Dans Copii</span>
      </div>
      <h1 class="font-display font-bold text-white leading-[1.05] max-w-4xl text-3xl sm:text-4xl lg:text-5xl">
        Dansul care îi face<br />pe copii să strălucească
      </h1>
      <p class="mt-8 text-lg lg:text-xl text-white/90 max-w-xl leading-relaxed">
        Încredere, creativitate și bucurie — prin mișcare. Cursuri de dans pentru copii de toate vârstele, într-un mediu sigur și prietenos.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te" variant="mandarin" size="lg" />
        <CTAButton href="/orar-tarife/" label="Orar & Tarife" variant="outline" size="lg" />
      </div>
    </div>
  </section>

  <!-- ========== EDITORIAL SPLIT — De ce BloomArt ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text overflow-hidden" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
        <!-- Image side -->
        <div class="lg:col-span-5 relative">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden">
            <img
              src="/images/dans-copii/dans-copii-02.webp"
              alt="Copii dansând la BloomArt Academy"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Text side -->
        <div class="lg:col-span-6 lg:col-start-7">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-12 h-px bg-brand"></span>
            <span class="text-brand text-sm font-semibold tracking-wider">De Ce BloomArt</span>
          </div>
          <h2 class="text-4xl sm:text-5xl font-display font-bold text-text leading-tight mb-8">
            Un loc în care copiii cresc prin dans
          </h2>
          <div class="space-y-5 text-text-light leading-relaxed text-lg">
            <p>
              La BloomArt Academy, dansul nu e doar despre pași — e despre dezvoltare. Copiii învață coordonare, muzicalitate și disciplină, totul într-o atmosferă caldă, prietenoasă, unde fiecare copil se simte binevenit.
            </p>
            <p>
              Oferim 3 stiluri de dans adaptate pe grupe de vârstă: Dans Modern, Street Dance și Baby Dance (de la 3 ani). Fiecare curs este construit să respecte ritmul și nivelul copilului.
            </p>
            <p>
              Toți antrenorii noștri sunt acreditați de Federația Română de Dans Sportiv, cu experiență dedicată lucrului cu copiii. Siguranța, răbdarea și bucuria sunt la baza fiecărei lecții.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== COURSE CARDS ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Stiluri de Dans</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Alege cursul potrivit
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        3 stiluri de dans, grupe pe vârste, antrenori dedicați. Descoperă ce i se potrivește copilului tău.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <CourseCardOverlay title="Dans Modern" href="/cursuri-dans-copii/dans-modern/" image="/images/dans-copii/dans-copii-03.webp" />
        <CourseCardOverlay title="Street Dance" href="/cursuri-dans-copii/street-dance/" image="/images/dans-copii/dans-copii-05.webp" />
        <CourseCardOverlay title="Baby Dance" href="/cursuri-dans-copii/baby-dance/" image="/images/dans-copii/dans-copii-06.webp" />
      </div>
    </div>
  </section>

  <!-- ========== BENEFITS — Numbered Steps ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">De Ce Dans</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Ce aduce dansul în viața copilului tău
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Dansul dezvoltă corpul și mintea, într-un mod natural și plin de bucurie.
      </p>

      <div class="grid md:grid-cols-2 gap-x-16 gap-y-16">
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">01</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Dezvoltare fizică</h3>
            <p class="text-text-light leading-relaxed">
              Coordonare, flexibilitate, postură corectă și rezistență fizică — toate dezvoltate natural prin mișcare și ritm, într-un mod adaptat vârstei.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">02</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Încredere în sine</h3>
            <p class="text-text-light leading-relaxed">
              Copiii care dansează învață să se exprime, să lucreze în echipă și să-și depășească timiditatea. Dansul construiește o încredere care se vede și în afara sălii.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">03</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Disciplină prin joacă</h3>
            <p class="text-text-light leading-relaxed">
              Lecțiile sunt structurate, dar distractive. Copiii învață să respecte reguli, să fie atenți și să persevereze — totul prin joc și muzică.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">04</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Antrenori dedicați</h3>
            <p class="text-text-light leading-relaxed">
              Acreditați de Federația Română de Dans Sportiv, cu experiență în lucrul cu copiii. Răbdare, profesionalism și un zâmbet la fiecare lecție.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRAINERS ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Antrenorii</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Cine îi ghidează pe cei mici
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Antrenori pasionați, cu experiență dedicată lucrului cu copiii.
      </p>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12 max-w-4xl">
        <!-- Giulia -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 transition-all duration-300">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/images/team/giulia-craciun.webp"
              alt="Giulia — Antrenor dans copii și competițional"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-xl font-display font-bold text-text mb-1">Giulia</h3>
            <p class="text-brand text-sm font-semibold tracking-wide mb-4">Dans Modern Copii</p>
            <p class="text-text-light leading-relaxed text-sm">
              Practicantă de dans competițional de la vârsta de 3 ani, cu numeroase participări la campionate naționale și internaționale WDSF. Predă din 2018 — dans competițional, dans modern și formații de grup pentru copii.
            </p>
          </div>
        </div>

        <!-- Irina -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 transition-all duration-300">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="/images/team/irina-portrait.webp"
              alt="Irina Florea — Antrenor Street Dance"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-xl font-display font-bold text-text mb-1">Irina Florea</h3>
            <p class="text-brand text-sm font-semibold tracking-wide mb-4">Street Dance Copii</p>
            <p class="text-text-light leading-relaxed text-sm">
              Peste 15 ani de experiență în Dancehall, Hip-Hop și Waacking. Absolventă a Școlii de Arte București, specializarea Coregrafie. Figură de referință în promovarea culturii Dancehall în România.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ACCORDION ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Întrebări Frecvente</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-16">
        Tot ce trebuie să știi
      </h2>

      <div class="max-w-3xl space-y-4">
        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">De la ce vârstă poate începe copilul meu?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              De la 3 ani! Cursul de Baby Dance este special creat pentru copiii de 3-5 ani, cu exerciții ludice și multă muzică. De la 6 ani, copiii pot participa la Dans Modern sau Street Dance.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Copilul meu nu a dansat niciodată. E ok?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Absolut! Majoritatea copiilor care vin la noi sunt la primul contact cu dansul. Cursurile sunt structurate pe niveluri și grupe de vârstă, iar antrenorii adaptează ritmul lecțiilor la fiecare copil.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Cum sunt organizate grupele?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Grupele sunt organizate pe vârste și nivel de experiență, cu un număr limitat de participanți pentru a asigura atenția individuală. Astfel, fiecare copil primește ghidajul de care are nevoie.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Prima ședință e gratuită?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Da! Prima ședință este gratuită la oricare dintre cursurile noastre pentru copii. Este o ocazie excelentă pentru copil să experimenteze atmosfera și pentru voi să cunoașteți antrenorul.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Ce trebuie să aducă copilul la curs?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Ținută confortabilă de sport și încălțăminte curată de interior (adidași sau pantofi de dans, în funcție de stilul ales). Nu e nevoie de echipament special — doar energie și chef de dans!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-32 lg:py-40 overflow-hidden" data-reveal>
    <img
      src="/images/dans-copii/dans-copii-03.webp"
      alt="Dans copii BloomArt"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand to-brand-dark"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-mandarin text-sm font-semibold tracking-wider mb-6 block">Primul Pas</span>
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-white leading-[1.05] mb-8">
        Începe aventura în dans a copilului tău
      </h2>
      <p class="text-xl text-text-light mb-12 max-w-xl mx-auto">
        Prima ședință e gratuită. Hai să descoperim împreună stilul de dans perfect.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te Acum" variant="mandarin" size="lg" />
        <CTAButton href="https://wa.me/40725975464" label="WhatsApp" variant="secondary" size="lg" />
      </div>
    </div>
  </section>

</Layout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = item?.querySelector('.faq-icon');
      const isOpen = !content?.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-item').forEach(faq => {
        faq.querySelector('.faq-content')?.classList.add('hidden');
        faq.querySelector('.faq-icon')?.classList.remove('rotate-180');
        faq.querySelector('.faq-trigger')?.classList.remove('text-brand');
      });

      // Toggle current
      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        btn.classList.add('text-brand');
      }
    });
  });

  // Scroll reveal
  const revealEls = document.querySelectorAll('[data-reveal]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed', 'animate-fade-up');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => obs.observe(el));
</script>
