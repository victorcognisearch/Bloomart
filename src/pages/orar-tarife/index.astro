---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<Layout
  title="Orar & Tarife"
  description="Program cursuri de dans și tarife BloomArt Academy București. Abonamente flexibile, lecții individuale și promoții."
>

  <!-- ========== HERO ========== -->
  <section class="relative pt-20 pb-10 lg:pt-24 lg:pb-12 overflow-hidden bg-brand">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-1 bg-mandarin rounded-full"></span>
        <span class="text-white text-sm font-semibold tracking-wider">Orar & Tarife</span>
      </div>
      <h1 class="font-display font-bold text-white leading-[1.05] max-w-4xl text-3xl sm:text-4xl lg:text-5xl">
        Program și tarife
      </h1>
      <p class="mt-5 text-base lg:text-lg text-white/90 max-w-2xl leading-relaxed">
        Alege abonamentul care ți se potrivește și vino la dans. Prima ședință e mereu gratuită.
      </p>
    </div>
  </section>

  <!-- ========== ORAR (Schedule) ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Program</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Orarul cursurilor
      </h2>
      <p class="text-text-light text-lg mb-12 max-w-2xl">
        Cursurile au loc de luni până joi, între orele 18:00 și 21:00.
      </p>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="bg-surface-alt text-brand font-display font-bold tracking-wide text-sm px-6 py-4 text-left rounded-tl-xl border-b border-gray-200">Ora</th>
              <th class="bg-surface-alt text-brand font-display font-bold tracking-wide text-sm px-6 py-4 text-center border-b border-gray-200">Luni</th>
              <th class="bg-surface-alt text-brand font-display font-bold tracking-wide text-sm px-6 py-4 text-center border-b border-gray-200">Marți</th>
              <th class="bg-surface-alt text-brand font-display font-bold tracking-wide text-sm px-6 py-4 text-center border-b border-gray-200">Miercuri</th>
              <th class="bg-surface-alt text-brand font-display font-bold tracking-wide text-sm px-6 py-4 text-center rounded-tr-xl border-b border-gray-200">Joi</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-200">
              <td class="px-6 py-5 text-text font-semibold whitespace-nowrap">18:00 – 19:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium">Dans Modern Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand-light text-white px-3 py-1.5 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium">Dans Modern Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand-light text-white px-3 py-1.5 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
              </td>
            </tr>
            <tr class="border-b border-gray-200">
              <td class="px-6 py-5 text-text font-semibold whitespace-nowrap">19:00 – 20:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-text-light">—</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-text-light">—</span>
              </td>
            </tr>
            <tr>
              <td class="px-6 py-5 text-text font-semibold whitespace-nowrap">20:00 – 21:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-mandarin text-white px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Adulți</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-text-light">—</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-mandarin text-white px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Adulți</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-text-light">—</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="md:hidden space-y-6">
        <!-- Luni -->
        <div class="bg-surface-alt rounded-xl border border-gray-200 overflow-hidden">
          <div class="bg-surface-alt px-5 py-3 border-b border-gray-200">
            <h3 class="text-brand font-display font-bold tracking-wide text-sm">Luni</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">18:00 – 19:00</span>
              <span class="bg-brand text-white px-3 py-1 rounded-lg text-sm font-medium">Dans Modern Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">19:00 – 20:00</span>
              <span class="bg-brand text-white px-3 py-1 rounded-lg text-sm font-medium">Street Dance Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">20:00 – 21:00</span>
              <span class="bg-mandarin text-white px-3 py-1 rounded-lg text-sm font-medium">Street Dance Adulți</span>
            </div>
          </div>
        </div>

        <!-- Marti -->
        <div class="bg-surface-alt rounded-xl border border-gray-200 overflow-hidden">
          <div class="bg-surface-alt px-5 py-3 border-b border-gray-200">
            <h3 class="text-brand font-display font-bold tracking-wide text-sm">Marți</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">18:00 – 19:00</span>
              <span class="bg-brand-light text-white px-3 py-1 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
            </div>
          </div>
        </div>

        <!-- Miercuri -->
        <div class="bg-surface-alt rounded-xl border border-gray-200 overflow-hidden">
          <div class="bg-surface-alt px-5 py-3 border-b border-gray-200">
            <h3 class="text-brand font-display font-bold tracking-wide text-sm">Miercuri</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">18:00 – 19:00</span>
              <span class="bg-brand text-white px-3 py-1 rounded-lg text-sm font-medium">Dans Modern Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">19:00 – 20:00</span>
              <span class="bg-brand text-white px-3 py-1 rounded-lg text-sm font-medium">Street Dance Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">20:00 – 21:00</span>
              <span class="bg-mandarin text-white px-3 py-1 rounded-lg text-sm font-medium">Street Dance Adulți</span>
            </div>
          </div>
        </div>

        <!-- Joi -->
        <div class="bg-surface-alt rounded-xl border border-gray-200 overflow-hidden">
          <div class="bg-surface-alt px-5 py-3 border-b border-gray-200">
            <h3 class="text-brand font-display font-bold tracking-wide text-sm">Joi</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-text-light text-sm">18:00 – 19:00</span>
              <span class="bg-brand-light text-white px-3 py-1 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-6 mt-8">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-brand"></span>
          <span class="text-text-light text-sm">Copii</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-brand-light"></span>
          <span class="text-text-light text-sm">Baby Dance</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-mandarin"></span>
          <span class="text-text-light text-sm">Adulți</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TARIFE (Pricing Cards) ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Abonamente</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Tarife cursuri de grup
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Alege varianta potrivită pentru tine. Toate abonamentele includ acces la cursurile din program.
      </p>

      <div class="grid sm:grid-cols-3 gap-6 lg:gap-8">
        <!-- Drop-in -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl p-8 flex flex-col hover:border-gray-300 transition-all duration-300">
          <p class="text-brand text-sm font-semibold tracking-wider mb-4">Drop-in</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-text">55</span>
            <span class="text-text-light text-lg ml-1">RON</span>
          </div>
          <p class="text-text-light mb-2">1 ședință</p>
          <p class="text-text-light text-sm mb-8">Ideal pentru a testa un curs nou.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Rezervă locul" variant="outline" size="md" />
          </div>
        </div>

        <!-- 4 sessions — standard -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl p-8 flex flex-col hover:border-gray-300 transition-all duration-300">
          <p class="text-brand text-sm font-semibold tracking-wider mb-4">Standard</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-text">200</span>
            <span class="text-text-light text-lg ml-1">RON</span>
          </div>
          <p class="text-text-light mb-2">4 ședințe / lună</p>
          <p class="text-text-light text-sm mb-8">50 RON / ședință — 1 curs pe săptămână.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Alege abonamentul" variant="outline" size="md" />
          </div>
        </div>

        <!-- 8 sessions — best value -->
        <div class="relative bg-surface-alt border-2 border-brand rounded-2xl p-8 flex flex-col shadow-[0_0_40px_rgba(62,179,145,0.1)]">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-brand text-dark text-xs font-bold tracking-wide px-4 py-1 rounded-full">Cel mai popular</span>
          <p class="text-brand text-sm font-semibold tracking-wider mb-4">Complet</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-text">280</span>
            <span class="text-text-light text-lg ml-1">RON</span>
          </div>
          <p class="text-text-light mb-2">8 ședințe / lună</p>
          <p class="text-text-light text-sm mb-8">35 RON / ședință — 2 cursuri pe săptămână.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Alege abonamentul" variant="primary" size="md" />
          </div>
        </div>
      </div>

      <p class="text-center text-text-light text-sm mt-8">
        Prima ședință este întotdeauna gratuită, indiferent de abonament.
      </p>
    </div>
  </section>

  <!-- ========== LECȚII INDIVIDUALE ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Private</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Lecții individuale
      </h2>
      <p class="text-text-light text-lg mb-12 max-w-2xl">
        Lecții private, personalizate pe nevoile tale — ideale pentru dansul mirilor sau progres accelerat.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-surface-alt border border-gray-200 rounded-xl p-6 text-center hover:border-gray-300 transition-all duration-300">
          <p class="text-text-light text-sm tracking-wide mb-3">1 ședință</p>
          <p class="text-3xl font-display font-bold text-text mb-1">250 <span class="text-lg text-text-light">RON</span></p>
          <p class="text-text-light text-sm">45 minute</p>
        </div>
        <div class="bg-surface-alt border border-gray-200 rounded-xl p-6 text-center hover:border-gray-300 transition-all duration-300">
          <p class="text-text-light text-sm tracking-wide mb-3">5 ședințe</p>
          <p class="text-3xl font-display font-bold text-text mb-1">1200 <span class="text-lg text-text-light">RON</span></p>
          <p class="text-text-light text-sm">240 RON / ședință</p>
        </div>
        <div class="bg-surface-alt border border-gray-200 rounded-xl p-6 text-center hover:border-gray-300 transition-all duration-300">
          <p class="text-text-light text-sm tracking-wide mb-3">7 ședințe</p>
          <p class="text-3xl font-display font-bold text-text mb-1">1700 <span class="text-lg text-text-light">RON</span></p>
          <p class="text-text-light text-sm">243 RON / ședință</p>
        </div>
        <div class="relative bg-surface-alt border-2 border-brand rounded-xl p-6 text-center shadow-[0_0_30px_rgba(62,179,145,0.08)]">
          <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-brand text-dark text-xs font-bold tracking-wide px-3 py-0.5 rounded-full">Best value</span>
          <p class="text-text-light text-sm tracking-wide mb-3">10 ședințe</p>
          <p class="text-3xl font-display font-bold text-text mb-1">2400 <span class="text-lg text-text-light">RON</span></p>
          <p class="text-text-light text-sm">240 RON / ședință</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <CTAButton href="/formular-inscriere/" label="Programează o lecție" variant="secondary" size="md" />
      </div>
    </div>
  </section>

  <!-- ========== PROMOȚII ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Promoții</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Adu un prieten, dansează gratis
      </h2>
      <p class="text-text-light text-lg mb-12 max-w-2xl">
        Adu un prieten sau un membru al familiei care își cumpără cel puțin o lună de abonament și beneficiezi de reducerile de mai jos.
      </p>

      <div class="max-w-2xl">
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden">
          <!-- Header -->
          <div class="grid grid-cols-3 bg-surface-alt border-b border-gray-200">
            <div class="px-6 py-4 text-brand font-display font-bold tracking-wide text-sm">Reducere</div>
            <div class="px-6 py-4 text-brand font-display font-bold tracking-wide text-sm text-center">Luni abonament</div>
            <div class="px-6 py-4 text-brand font-display font-bold tracking-wide text-sm text-center">Prieteni / Familie</div>
          </div>
          <!-- Rows -->
          <div class="grid grid-cols-3 border-b border-gray-200">
            <div class="px-6 py-4 text-text font-semibold">50% reducere</div>
            <div class="px-6 py-4 text-text text-center">1 lună</div>
            <div class="px-6 py-4 text-text text-center">1</div>
          </div>
          <div class="grid grid-cols-3 border-b border-gray-200">
            <div class="px-6 py-4 text-text font-semibold">100% reducere</div>
            <div class="px-6 py-4 text-text text-center">2 luni</div>
            <div class="px-6 py-4 text-text text-center">2</div>
          </div>
          <div class="grid grid-cols-3">
            <div class="px-6 py-4 text-text font-semibold">100% reducere</div>
            <div class="px-6 py-4 text-text text-center">2 luni</div>
            <div class="px-6 py-4 text-text text-center">3+</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-32 lg:py-40 overflow-hidden" data-reveal>
    <img
      src="/images/homepage/couples-dancing.webp"
      alt="Dans BloomArt"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand to-brand-dark"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-mandarin text-sm font-semibold tracking-wider mb-6 block">Începe acum</span>
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-white leading-[1.05] mb-8">
        Prima ședință e gratuită
      </h2>
      <p class="text-xl text-text-light mb-12 max-w-xl mx-auto">
        Vino la o ședință de probă și descoperă ce stil de dans ți se potrivește.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te Acum" variant="mandarin" size="lg" />
        <CTAButton href="https://wa.me/40746423423" label="WhatsApp" variant="secondary" size="lg" />
      </div>
    </div>
  </section>

</Layout>

<script>
  const revealEls = document.querySelectorAll('[data-reveal]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed', 'animate-fade-up');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => obs.observe(el));
</script>
