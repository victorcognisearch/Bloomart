---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<Layout
  title="Orar & Tarife"
  description="Program cursuri de dans și tarife BloomArt Academy București. Abonamente flexibile, lecții individuale și promoții."
>

  <!-- ========== HERO ========== -->
  <section class="bg-dark pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Orar & Tarife</span>
      </div>
      <h1 class="text-[clamp(2.5rem,6vw,5.5rem)] font-display font-bold text-white leading-[0.95] max-w-4xl">
        Program și tarife
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-white/50 max-w-2xl leading-relaxed">
        Alege abonamentul care ți se potrivește și vino la dans. Prima ședință e mereu gratuită.
      </p>
    </div>
  </section>

  <!-- ========== ORAR (Schedule) ========== -->
  <section class="bg-[#0a0a0f] py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Program</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-4">
        Orarul cursurilor
      </h2>
      <p class="text-white/40 text-lg mb-12 max-w-2xl">
        Cursurile au loc de luni până joi, între orele 18:00 și 21:00.
      </p>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="bg-dark-light text-brand font-display font-bold uppercase tracking-wider text-sm px-6 py-4 text-left rounded-tl-xl border-b border-white/10">Ora</th>
              <th class="bg-dark-light text-brand font-display font-bold uppercase tracking-wider text-sm px-6 py-4 text-center border-b border-white/10">Luni</th>
              <th class="bg-dark-light text-brand font-display font-bold uppercase tracking-wider text-sm px-6 py-4 text-center border-b border-white/10">Marți</th>
              <th class="bg-dark-light text-brand font-display font-bold uppercase tracking-wider text-sm px-6 py-4 text-center border-b border-white/10">Miercuri</th>
              <th class="bg-dark-light text-brand font-display font-bold uppercase tracking-wider text-sm px-6 py-4 text-center rounded-tr-xl border-b border-white/10">Joi</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-white/5">
              <td class="px-6 py-5 text-white font-semibold whitespace-nowrap">18:00 – 19:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand/10 text-brand-light px-3 py-1.5 rounded-lg text-sm font-medium">Dans Modern Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-accent/10 text-accent-light px-3 py-1.5 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand/10 text-brand-light px-3 py-1.5 rounded-lg text-sm font-medium">Dans Modern Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-accent/10 text-accent-light px-3 py-1.5 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
              </td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="px-6 py-5 text-white font-semibold whitespace-nowrap">19:00 – 20:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand/10 text-brand-light px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-white/20">—</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-brand/10 text-brand-light px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Copii</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-white/20">—</span>
              </td>
            </tr>
            <tr>
              <td class="px-6 py-5 text-white font-semibold whitespace-nowrap">20:00 – 21:00</td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-purple-500/10 text-purple-300 px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Adulți</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-white/20">—</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="inline-block bg-purple-500/10 text-purple-300 px-3 py-1.5 rounded-lg text-sm font-medium">Street Dance Adulți</span>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-white/20">—</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="md:hidden space-y-6">
        <!-- Luni -->
        <div class="bg-dark-light/50 rounded-xl border border-white/5 overflow-hidden">
          <div class="bg-dark-light px-5 py-3 border-b border-white/10">
            <h3 class="text-brand font-display font-bold uppercase tracking-wider text-sm">Luni</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">18:00 – 19:00</span>
              <span class="bg-brand/10 text-brand-light px-3 py-1 rounded-lg text-sm font-medium">Dans Modern Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">19:00 – 20:00</span>
              <span class="bg-brand/10 text-brand-light px-3 py-1 rounded-lg text-sm font-medium">Street Dance Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">20:00 – 21:00</span>
              <span class="bg-purple-500/10 text-purple-300 px-3 py-1 rounded-lg text-sm font-medium">Street Dance Adulți</span>
            </div>
          </div>
        </div>

        <!-- Marti -->
        <div class="bg-dark-light/50 rounded-xl border border-white/5 overflow-hidden">
          <div class="bg-dark-light px-5 py-3 border-b border-white/10">
            <h3 class="text-brand font-display font-bold uppercase tracking-wider text-sm">Marți</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">18:00 – 19:00</span>
              <span class="bg-accent/10 text-accent-light px-3 py-1 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
            </div>
          </div>
        </div>

        <!-- Miercuri -->
        <div class="bg-dark-light/50 rounded-xl border border-white/5 overflow-hidden">
          <div class="bg-dark-light px-5 py-3 border-b border-white/10">
            <h3 class="text-brand font-display font-bold uppercase tracking-wider text-sm">Miercuri</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">18:00 – 19:00</span>
              <span class="bg-brand/10 text-brand-light px-3 py-1 rounded-lg text-sm font-medium">Dans Modern Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">19:00 – 20:00</span>
              <span class="bg-brand/10 text-brand-light px-3 py-1 rounded-lg text-sm font-medium">Street Dance Copii</span>
            </div>
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">20:00 – 21:00</span>
              <span class="bg-purple-500/10 text-purple-300 px-3 py-1 rounded-lg text-sm font-medium">Street Dance Adulți</span>
            </div>
          </div>
        </div>

        <!-- Joi -->
        <div class="bg-dark-light/50 rounded-xl border border-white/5 overflow-hidden">
          <div class="bg-dark-light px-5 py-3 border-b border-white/10">
            <h3 class="text-brand font-display font-bold uppercase tracking-wider text-sm">Joi</h3>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4 flex justify-between items-center">
              <span class="text-white/50 text-sm">18:00 – 19:00</span>
              <span class="bg-accent/10 text-accent-light px-3 py-1 rounded-lg text-sm font-medium">Baby Dance 3–5 ani</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-6 mt-8">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-brand/30"></span>
          <span class="text-white/40 text-sm">Copii</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-accent/30"></span>
          <span class="text-white/40 text-sm">Baby Dance</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-purple-500/30"></span>
          <span class="text-white/40 text-sm">Adulți</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TARIFE (Pricing Cards) ========== -->
  <section class="bg-dark py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Abonamente</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-4">
        Tarife cursuri de grup
      </h2>
      <p class="text-white/40 text-lg mb-16 max-w-2xl">
        Alege varianta potrivită pentru tine. Toate abonamentele includ acces la cursurile din program.
      </p>

      <div class="grid sm:grid-cols-3 gap-6 lg:gap-8">
        <!-- Drop-in -->
        <div class="bg-dark-light/50 border border-white/10 rounded-2xl p-8 flex flex-col hover:border-white/20 transition-all duration-300">
          <p class="text-brand text-sm font-semibold uppercase tracking-[0.2em] mb-4">Drop-in</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-white">55</span>
            <span class="text-white/40 text-lg ml-1">RON</span>
          </div>
          <p class="text-white/40 mb-2">1 ședință</p>
          <p class="text-white/30 text-sm mb-8">Ideal pentru a testa un curs nou.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Rezervă locul" variant="outline" size="md" />
          </div>
        </div>

        <!-- 4 sessions — standard -->
        <div class="bg-dark-light/50 border border-white/10 rounded-2xl p-8 flex flex-col hover:border-white/20 transition-all duration-300">
          <p class="text-brand text-sm font-semibold uppercase tracking-[0.2em] mb-4">Standard</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-white">200</span>
            <span class="text-white/40 text-lg ml-1">RON</span>
          </div>
          <p class="text-white/40 mb-2">4 ședințe / lună</p>
          <p class="text-white/30 text-sm mb-8">50 RON / ședință — 1 curs pe săptămână.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Alege abonamentul" variant="outline" size="md" />
          </div>
        </div>

        <!-- 8 sessions — best value -->
        <div class="relative bg-dark-light/50 border-2 border-brand rounded-2xl p-8 flex flex-col shadow-[0_0_40px_rgba(62,179,145,0.1)]">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-brand text-dark text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Cel mai popular</span>
          <p class="text-brand text-sm font-semibold uppercase tracking-[0.2em] mb-4">Complet</p>
          <div class="mb-6">
            <span class="text-5xl font-display font-bold text-white">280</span>
            <span class="text-white/40 text-lg ml-1">RON</span>
          </div>
          <p class="text-white/40 mb-2">8 ședințe / lună</p>
          <p class="text-white/30 text-sm mb-8">35 RON / ședință — 2 cursuri pe săptămână.</p>
          <div class="mt-auto">
            <CTAButton href="/formular-inscriere/" label="Alege abonamentul" variant="primary" size="md" />
          </div>
        </div>
      </div>

      <p class="text-center text-white/30 text-sm mt-8">
        Prima ședință este întotdeauna gratuită, indiferent de abonament.
      </p>
    </div>
  </section>

  <!-- ========== LECȚII INDIVIDUALE ========== -->
  <section class="bg-[#0a0a0f] py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Private</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-4">
        Lecții individuale
      </h2>
      <p class="text-white/40 text-lg mb-12 max-w-2xl">
        Lecții private, personalizate pe nevoile tale — ideale pentru dansul mirilor sau progres accelerat.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-dark-light/50 border border-white/10 rounded-xl p-6 text-center hover:border-white/20 transition-all duration-300">
          <p class="text-white/40 text-sm uppercase tracking-wider mb-3">1 ședință</p>
          <p class="text-3xl font-display font-bold text-white mb-1">250 <span class="text-lg text-white/40">RON</span></p>
          <p class="text-white/30 text-sm">45 minute</p>
        </div>
        <div class="bg-dark-light/50 border border-white/10 rounded-xl p-6 text-center hover:border-white/20 transition-all duration-300">
          <p class="text-white/40 text-sm uppercase tracking-wider mb-3">5 ședințe</p>
          <p class="text-3xl font-display font-bold text-white mb-1">1200 <span class="text-lg text-white/40">RON</span></p>
          <p class="text-white/30 text-sm">240 RON / ședință</p>
        </div>
        <div class="bg-dark-light/50 border border-white/10 rounded-xl p-6 text-center hover:border-white/20 transition-all duration-300">
          <p class="text-white/40 text-sm uppercase tracking-wider mb-3">7 ședințe</p>
          <p class="text-3xl font-display font-bold text-white mb-1">1700 <span class="text-lg text-white/40">RON</span></p>
          <p class="text-white/30 text-sm">243 RON / ședință</p>
        </div>
        <div class="relative bg-dark-light/50 border-2 border-brand rounded-xl p-6 text-center shadow-[0_0_30px_rgba(62,179,145,0.08)]">
          <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-brand text-dark text-xs font-bold uppercase tracking-wider px-3 py-0.5 rounded-full">Best value</span>
          <p class="text-white/40 text-sm uppercase tracking-wider mb-3">10 ședințe</p>
          <p class="text-3xl font-display font-bold text-white mb-1">2400 <span class="text-lg text-white/40">RON</span></p>
          <p class="text-white/30 text-sm">240 RON / ședință</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <CTAButton href="/formular-inscriere/" label="Programează o lecție" variant="secondary" size="md" />
      </div>
    </div>
  </section>

  <!-- ========== PROMOȚII ========== -->
  <section class="bg-dark py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Promoții</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-4">
        Adu un prieten, dansează gratis
      </h2>
      <p class="text-white/40 text-lg mb-12 max-w-2xl">
        Adu un prieten sau un membru al familiei care își cumpără cel puțin o lună de abonament și beneficiezi de reducerile de mai jos.
      </p>

      <div class="max-w-2xl">
        <div class="bg-dark-light/50 border border-white/10 rounded-2xl overflow-hidden">
          <!-- Header -->
          <div class="grid grid-cols-3 bg-dark-light border-b border-white/10">
            <div class="px-6 py-4 text-brand font-display font-bold uppercase tracking-wider text-sm">Reducere</div>
            <div class="px-6 py-4 text-brand font-display font-bold uppercase tracking-wider text-sm text-center">Luni abonament</div>
            <div class="px-6 py-4 text-brand font-display font-bold uppercase tracking-wider text-sm text-center">Prieteni / Familie</div>
          </div>
          <!-- Rows -->
          <div class="grid grid-cols-3 border-b border-white/5">
            <div class="px-6 py-4 text-white font-semibold">50% reducere</div>
            <div class="px-6 py-4 text-white/60 text-center">1 lună</div>
            <div class="px-6 py-4 text-white/60 text-center">1</div>
          </div>
          <div class="grid grid-cols-3 border-b border-white/5">
            <div class="px-6 py-4 text-white font-semibold">100% reducere</div>
            <div class="px-6 py-4 text-white/60 text-center">2 luni</div>
            <div class="px-6 py-4 text-white/60 text-center">2</div>
          </div>
          <div class="grid grid-cols-3">
            <div class="px-6 py-4 text-white font-semibold">100% reducere</div>
            <div class="px-6 py-4 text-white/60 text-center">2 luni</div>
            <div class="px-6 py-4 text-white/60 text-center">3+</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-32 lg:py-40 overflow-hidden" data-reveal>
    <img
      src="/images/homepage/couples-dancing.webp"
      alt="Dans BloomArt"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-dark via-dark/90 to-dark"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em] mb-6 block">Începe acum</span>
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-white leading-[0.95] mb-8">
        Prima ședință e gratuită
      </h2>
      <p class="text-xl text-white/40 mb-12 max-w-xl mx-auto">
        Vino la o ședință de probă și descoperă ce stil de dans ți se potrivește.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te Acum" variant="primary" size="lg" />
        <CTAButton href="https://wa.me/40746423423" label="WhatsApp" variant="secondary" size="lg" />
      </div>
    </div>
  </section>

</Layout>

<script>
  const revealEls = document.querySelectorAll('[data-reveal]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed', 'animate-fade-up');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => obs.observe(el));
</script>
