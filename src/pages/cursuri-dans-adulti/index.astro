---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import CourseCardOverlay from '../../components/CourseCardOverlay.astro';
---

<Layout
  title="Cursuri Dans Adulți București"
  description="Cursuri de dans pentru adulți la BloomArt Academy București — Street Dance, Dans de Societate. Orice nivel, orice vârstă. Antrenori acreditați."
>

  <!-- ========== HERO ========== -->
  <section class="relative pt-20 pb-10 lg:pt-24 lg:pb-12 overflow-hidden bg-brand">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-1 bg-mandarin rounded-full"></span>
        <span class="text-white text-sm font-semibold tracking-wider">Dans Adulți</span>
      </div>
      <h1 class="font-display font-bold text-white leading-[1.05] max-w-4xl text-3xl sm:text-4xl lg:text-5xl">
        Dansul nu are vârstă,<br />doar bucurie
      </h1>
      <p class="mt-8 text-lg lg:text-xl text-white/90 max-w-xl leading-relaxed">
        Nu contează dacă nu ai dansat niciodată sau dansezi de ani de zile — la BloomArt găsești locul tău pe ringul de dans.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te" variant="mandarin" size="lg" />
        <CTAButton href="/orar-tarife/" label="Orar & Tarife" variant="outline" size="lg" />
      </div>
    </div>
  </section>

  <!-- ========== EDITORIAL SPLIT — De ce BloomArt ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text overflow-hidden" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
        <div class="lg:col-span-5 relative">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden">
            <img
              src="/images/grupa-adulti/grupa-adulti-2-1-reworked-website.webp"
              alt="Adulți dansând la BloomArt Academy"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-12 h-px bg-brand"></span>
            <span class="text-brand text-sm font-semibold tracking-wider">De Ce BloomArt</span>
          </div>
          <h2 class="text-4xl sm:text-5xl font-display font-bold text-text leading-tight mb-8">
            Mai mult decât o școală de dans
          </h2>
          <div class="space-y-5 text-text-light leading-relaxed text-lg">
            <p>
              BloomArt Academy este un loc prietenos, familial, unde fiecare cursant — indiferent de vârstă sau nivel — se simte binevenit. Aici nu există judecată, doar pași înainte.
            </p>
            <p>
              Oferim două stiluri de dans pentru adulți: Street Dance (Hip-Hop, Dancehall, Waacking) și Dans de Societate (ballroom și latin). Cursurile sunt organizate pe niveluri, cu program seara și în weekend, pentru a se potrivi oricărui stil de viață.
            </p>
            <p>
              Toți antrenorii noștri sunt acreditați de Federația Română de Dans Sportiv, cu peste 10 ani de experiență. Vii pentru dans, rămâi pentru comunitate.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== COURSE CARDS ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Stiluri de Dans</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Alege stilul tău
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Două lumi diferite, aceeași pasiune. Descoperă ce ți se potrivește — sau încearcă-le pe amândouă.
      </p>

      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl">
        <CourseCardOverlay title="Street Dance" href="/cursuri-dans-adulti/street-dance/" image="/images/homepage/virgil-stage.webp" />
        <CourseCardOverlay title="Dans de Societate" href="/cursuri-dans-adulti/dans-societate/" image="/images/homepage/couples-dancing.webp" />
      </div>
    </div>
  </section>

  <!-- ========== BENEFITS — Numbered Steps ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">De Ce Dans</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Ce câștigi prin dans
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Dincolo de pași și coregrafii, dansul transformă modul în care te simți.
      </p>

      <div class="grid md:grid-cols-2 gap-x-16 gap-y-16">
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">01</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Oricine poate dansa</h3>
            <p class="text-text-light leading-relaxed">
              Nu ai nevoie de experiență anterioară. Cursurile sunt pe niveluri — de la complet începător la avansat — și fiecare lecție e adaptată ritmului grupei.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">02</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Program flexibil</h3>
            <p class="text-text-light leading-relaxed">
              Cursuri seara și în weekend, gândite pentru programul tău de lucru. Abonamente lunare flexibile, cu 4 sau 8 ședințe pe lună.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">03</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Socializare și energie</h3>
            <p class="text-text-light leading-relaxed">
              Dansul e cel mai distractiv mod de a face mișcare, de a scăpa de stres și de a cunoaște oameni noi. Comunitatea BloomArt e caldă și primitoare.
            </p>
          </div>
        </div>
        <div class="group flex gap-6">
          <span class="text-5xl font-display font-bold text-gray-200 group-hover:text-brand/30 transition-colors">04</span>
          <div>
            <h3 class="text-xl font-display font-bold text-text mb-2">Antrenori acreditați</h3>
            <p class="text-text-light leading-relaxed">
              Acreditați de Federația Română de Dans Sportiv, cu peste 10 ani de experiență. Profesionalism, răbdare și o pasiune contagioasă pentru dans.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRAINERS ========== -->
  <section class="bg-white py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Antrenorii</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-4">
        Cu cine dansezi
      </h2>
      <p class="text-text-light text-lg mb-16 max-w-2xl">
        Antrenori cu experiență, pasiune și răbdare — gata să te ghideze de la primul pas.
      </p>

      <div class="grid sm:grid-cols-3 gap-6 lg:gap-8">
        <!-- Alina -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 transition-all duration-300 flex flex-col">
          <div class="shrink-0 overflow-hidden relative" style="height: 350px;">
            <img
              src="/images/team/alina-otelea.webp"
              alt="Alina Otelea — Co-fondator BloomArt Academy"
              class="absolute inset-0 w-full h-full object-cover" style="object-position: center 15%;"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6 flex flex-col flex-1">
            <h3 class="text-lg font-display font-bold text-text mb-1">Alina Otelea</h3>
            <p class="text-brand text-xs font-semibold tracking-wide mb-3">Co-fondator · Dans de Societate</p>
            <p class="text-text-light leading-relaxed text-sm">
              Carieră de performanță în dans sportiv încă din copilărie. Astăzi îmbină experiența competițională cu pasiunea de a ajuta fiecare cursant să descopere bucuria dansului.
            </p>
          </div>
        </div>

        <!-- Catalin -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 transition-all duration-300 flex flex-col">
          <div class="shrink-0 overflow-hidden relative" style="height: 350px;">
            <img
              src="/images/team/catalin-otelea.webp"
              alt="Cătălin Otelea — Co-fondator BloomArt Academy"
              class="absolute inset-0 w-full h-full object-cover" style="object-position: center 15%;"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6 flex flex-col flex-1">
            <h3 class="text-lg font-display font-bold text-text mb-1">Cătălin Otelea</h3>
            <p class="text-brand text-xs font-semibold tracking-wide mb-3">Co-fondator · Dans de Societate</p>
            <p class="text-text-light leading-relaxed text-sm">
              Energie debordantă și expertiză în salsa și dans sportiv competițional. Descris de cursanți ca fiind dedicat, răbdător și plin de viață.
            </p>
          </div>
        </div>

        <!-- Irina -->
        <div class="bg-surface-alt border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 transition-all duration-300 flex flex-col">
          <div class="shrink-0 overflow-hidden relative" style="height: 350px;">
            <img
              src="/images/team/irina-portrait-2.webp"
              alt="Irina Florea — Antrenor Street Dance"
              class="absolute inset-0 w-full h-full object-cover" style="object-position: center 20%;"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6 flex flex-col flex-1">
            <h3 class="text-lg font-display font-bold text-text mb-1">Irina Florea</h3>
            <p class="text-brand text-xs font-semibold tracking-wide mb-3">Street Dance</p>
            <p class="text-text-light leading-relaxed text-sm">
              Peste 15 ani de experiență în Dancehall, Hip-Hop și Waacking. Absolventă a Școlii de Arte București. Figură de referință în cultura Dancehall din România.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ACCORDION ========== -->
  <section class="bg-surface-alt py-24 lg:py-32 text-text" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold tracking-wider">Întrebări Frecvente</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-text leading-tight mb-16">
        Tot ce trebuie să știi
      </h2>

      <div class="max-w-3xl space-y-4">
        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Nu am dansat niciodată. E ok?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Absolut! Majoritatea cursanților noștri adulți sunt la primul contact cu dansul. Cursurile sunt organizate pe niveluri, iar antrenorii adaptează ritmul lecțiilor la fiecare grupă. Nu ai nevoie de talent — doar de chef de mișcare.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Pot veni singur/ă sau trebuie să vin în pereche?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Poți veni singur/ă fără nicio problemă! La Street Dance dansezi individual, iar la Dans de Societate se lucrează cu rotație de parteneri în cadrul grupei, deci nu ai nevoie să vii în pereche.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Cum sunt organizate grupele?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Grupele sunt organizate pe nivel de experiență — începător, intermediar și avansat. La prima ședință, antrenorul evaluează nivelul tău și te plasează în grupa potrivită. Numărul de locuri per grupă e limitat pentru atenție individuală.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Prima ședință e gratuită?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Da! Prima ședință este gratuită la oricare dintre cursurile noastre. Vino, experimentează atmosfera și decide dacă ți se potrivește — fără nicio obligație.
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Ce trebuie să port la curs?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Ținută confortabilă de sport și încălțăminte curată de interior. Pentru Street Dance — adidași. Pentru Dans de Societate — pantofi cu talpă netedă (sau pantofi de dans, dacă ai). Restul vine de la sine!
            </p>
          </div>
        </div>

        <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
          <button class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left">
            <span class="text-text font-display font-semibold text-lg pr-4">Care e programul cursurilor?</span>
            <svg class="faq-icon w-5 h-5 text-brand shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5">
            <p class="text-text-light leading-relaxed">
              Cursurile pentru adulți se desfășoară seara (după ora 18:00) și în weekend. Programul complet și tarifele le găsești pe pagina <a href="/orar-tarife/" class="text-brand hover:text-brand-light transition-colors underline underline-offset-2">Orar & Tarife</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-32 lg:py-40 overflow-hidden" data-reveal>
    <img
      src="/images/grupa-adulti/grupa-adulti-3-3-reworked-website.webp"
      alt="Dans adulți BloomArt"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand to-brand-dark"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-mandarin text-sm font-semibold tracking-wider mb-6 block">Primul Pas</span>
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-white leading-[1.05] mb-8">
        Începe aventura ta în dans
      </h2>
      <p class="text-xl text-text-light mb-12 max-w-xl mx-auto">
        Prima ședință e gratuită. Vino să descoperi ce stil ți se potrivește.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te Acum" variant="mandarin" size="lg" />
        <CTAButton href="https://wa.me/40725975464" label="WhatsApp" variant="secondary" size="lg" />
      </div>
    </div>
  </section>

</Layout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = item?.querySelector('.faq-icon');
      const isOpen = !content?.classList.contains('hidden');

      document.querySelectorAll('.faq-item').forEach(faq => {
        faq.querySelector('.faq-content')?.classList.add('hidden');
        faq.querySelector('.faq-icon')?.classList.remove('rotate-180');
        faq.querySelector('.faq-trigger')?.classList.remove('text-brand');
      });

      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        btn.classList.add('text-brand');
      }
    });
  });

  // Scroll reveal
  const revealEls = document.querySelectorAll('[data-reveal]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed', 'animate-fade-up');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => obs.observe(el));
</script>
