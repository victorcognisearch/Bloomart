---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<Layout
  title="Contact"
  description="Contactează BloomArt Academy — școala de dans din București. Telefon, email, WhatsApp, adresă și formular de contact."
>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[50vh] lg:min-h-[60vh] flex items-end pb-20 lg:pb-28 overflow-hidden bg-dark">
    <img
      src="/images/homepage/hero-group.webp"
      alt="Contact BloomArt Academy"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/40"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-px bg-brand-light"></span>
        <span class="text-brand-light text-sm font-semibold uppercase tracking-[0.2em]">Contact</span>
      </div>
      <h1 class="text-[clamp(2.5rem,6vw,5.5rem)] font-display font-bold text-white leading-[0.95] max-w-4xl">
        Hai să vorbim
      </h1>
      <p class="mt-8 text-lg lg:text-xl text-white/60 max-w-xl leading-relaxed">
        Ai întrebări despre cursuri, program sau tarife? Scrie-ne sau sună-ne — răspundem cu drag.
      </p>
    </div>
  </section>

  <!-- ========== CONTACT INFO + FORM — split layout ========== -->
  <section class="bg-[#0a0a0f] py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-8">

        <!-- Left — Contact Details -->
        <div class="lg:col-span-5">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-12 h-px bg-brand"></span>
            <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Informații</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-display font-bold text-white leading-tight mb-10">
            Detalii de contact
          </h2>

          <div class="space-y-8">
            <!-- Address -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-dark-light flex items-center justify-center">
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-1">Adresă</h3>
                <p class="text-white/50 leading-relaxed">Tabacarilor 14, București</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-dark-light flex items-center justify-center">
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-1">Telefon</h3>
                <a href="tel:+40746423423" class="text-white/50 hover:text-brand transition-colors duration-300">+40 746 423423</a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-dark-light flex items-center justify-center">
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-1">Email</h3>
                <a href="mailto:contact@bloomart.ro" class="text-white/50 hover:text-brand transition-colors duration-300">contact@bloomart.ro</a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-1">WhatsApp</h3>
                <a href="https://wa.me/40746423423" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-brand transition-colors duration-300">Scrie-ne pe WhatsApp</a>
              </div>
            </div>

            <!-- Schedule -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-dark-light flex items-center justify-center">
                <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-1">Program</h3>
                <p class="text-white/50 leading-relaxed">Luni – Vineri: 16:00 – 21:00</p>
                <p class="text-white/50 leading-relaxed">Sâmbătă: 10:00 – 14:00</p>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div class="mt-12 pt-8 border-t border-white/10">
            <h3 class="text-white font-display font-bold uppercase tracking-wide text-sm mb-4">Urmărește-ne</h3>
            <div class="flex gap-4">
              <a href="https://www.facebook.com/bloomart.academy/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-dark-light flex items-center justify-center text-white/40 hover:text-brand hover:bg-brand/10 transition-all duration-300" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/bloomart_academy/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-dark-light flex items-center justify-center text-white/40 hover:text-brand hover:bg-brand/10 transition-all duration-300" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="#" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-dark-light flex items-center justify-center text-white/40 hover:text-brand hover:bg-brand/10 transition-all duration-300" aria-label="TikTok">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right — Contact Form -->
        <div class="lg:col-span-6 lg:col-start-7">
          <div class="bg-dark-light rounded-2xl p-8 lg:p-12 border border-white/10">
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-white mb-2">Trimite-ne un mesaj</h2>
            <p class="text-white/40 mb-8">Completează formularul și te contactăm noi.</p>

            <form class="space-y-6" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-semibold text-white/60 uppercase tracking-wider mb-2">Nume</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full bg-dark/60 border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-300"
                    placeholder="Numele tău"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-white/60 uppercase tracking-wider mb-2">Telefon</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full bg-dark/60 border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-300"
                    placeholder="07xx xxx xxx"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-white/60 uppercase tracking-wider mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-dark/60 border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-300"
                  placeholder="email@exemplu.ro"
                />
              </div>

              <div>
                <label for="subject" class="block text-sm font-semibold text-white/60 uppercase tracking-wider mb-2">Subiect</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full bg-dark/60 border border-white/10 rounded-xl px-4 py-3.5 text-white/60 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-300 appearance-none"
                >
                  <option value="">Alege un subiect</option>
                  <option value="cursuri-adulti">Cursuri dans adulți</option>
                  <option value="cursuri-copii">Cursuri dans copii</option>
                  <option value="dansul-mirilor">Dansul mirilor</option>
                  <option value="orar-tarife">Orar și tarife</option>
                  <option value="altele">Altele</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-white/60 uppercase tracking-wider mb-2">Mesaj</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full bg-dark/60 border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-300 resize-none"
                  placeholder="Scrie mesajul tău aici..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-accent hover:bg-accent-light text-white font-bold uppercase tracking-wider text-sm py-4 rounded-full transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_0_30px_rgba(255,107,53,0.3)]"
              >
                Trimite mesajul
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== MAP ========== -->
  <section class="bg-dark py-24 lg:py-32" data-reveal>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-12 h-px bg-brand"></span>
        <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em]">Locație</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white leading-tight mb-12">
        Unde ne găsești
      </h2>
      <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/10">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d91158.63674668498!2d26.03222675!3d44.43780065!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40b1f93abf3cad4f%3A0xac0632e37c9ca628!2sBucharest%2C%20Romania!5e0!3m2!1sen!2sus!4v1"
          class="w-full h-full"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Locația BloomArt Academy pe hartă"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-32 lg:py-40 overflow-hidden" data-reveal>
    <img
      src="/images/homepage/couples-dancing.webp"
      alt="Dans BloomArt"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-dark via-dark/90 to-dark"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-brand text-sm font-semibold uppercase tracking-[0.2em] mb-6 block">Începe acum</span>
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold text-white leading-[0.95] mb-8">
        Prima ședință e gratuită
      </h2>
      <p class="text-xl text-white/40 mb-12 max-w-xl mx-auto">
        Vino la o ședință de probă și descoperă ce stil de dans ți se potrivește.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <CTAButton href="/formular-inscriere/" label="Înscrie-te Acum" variant="primary" size="lg" />
        <CTAButton href="https://wa.me/40746423423" label="WhatsApp" variant="secondary" size="lg" />
      </div>
    </div>
  </section>

</Layout>

<script>
  // Scroll-reveal
  const revealEls = document.querySelectorAll('[data-reveal]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed', 'animate-fade-up');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach(el => obs.observe(el));
</script>
